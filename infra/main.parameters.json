{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=eastus2}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "principalType": {
      "value": "${AZURE_PRINCIPAL_TYPE=User}"
    },
    "deployFunctionApp": {
      "value": "${DEPLOY_FUNCTION_APP=true}"
    },
    "embeddingModelName": {
      "value": "${AI_FOUNDRY_EMBEDDING_MODEL_NAME=text-embedding-3-large}"
    },
    "embeddingDeploymentName": {
      "value": "${AI_FOUNDRY_EMBEDDING_DEPLOYMENT_NAME=}"
    },
    "chatModelName": {
      "value": "${AI_FOUNDRY_CHAT_MODEL_NAME=gpt-4o-mini}"
    },
    "chatDeploymentName": {
      "value": "${AI_FOUNDRY_CHAT_DEPLOYMENT_NAME=}"
    },
    "cosmosDatabaseName": {
      "value": "${COSMOS_DB_DATABASE=ai_memory}"
    },
    "memoriesContainerName": {
      "value": "${COSMOS_DB_MEMORIES_CONTAINER=memories}"
    },
    "turnsContainerName": {
      "value": "${COSMOS_DB_TURNS_CONTAINER=memories_turns}"
    },
    "summariesContainerName": {
      "value": "${COSMOS_DB_SUMMARIES_CONTAINER=memories_summaries}"
    },
    "memoriesTurnsDefaultTtl": {
      "value": "${MEMORIES_TURNS_DEFAULT_TTL=2592000}"
    },
    "azureOpenAiApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION=2024-12-01-preview}"
    },
    "threadSummaryEveryN": {
      "value": "${THREAD_SUMMARY_EVERY_N=10}"
    },
    "factExtractionEveryN": {
      "value": "${FACT_EXTRACTION_EVERY_N=1}"
    },
    "dedupEveryN": {
      "value": "${DEDUP_EVERY_N=5}"
    },
    "userSummaryEveryN": {
      "value": "${USER_SUMMARY_EVERY_N=20}"
    },
    "maxBatchSize": {
      "value": "${MAX_BATCH_SIZE=20}"
    },
    "memoryProcessorOwner": {
      "value": "${MEMORY_PROCESSOR_OWNER=durable}"
    }
  }
}
